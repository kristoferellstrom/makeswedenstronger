# Public site URL used for canonical URLs, metadata, sitemap and JSON-LD.
NEXT_PUBLIC_SITE_URL=https://makeswedenstronger.vercel.app

# Optional: improves YouTube matching using Data API v3 playlistItems.
# Leave empty to use RSS feed fallback.
YOUTUBE_API_KEY=

# Internal page toggle. Keep false in production unless you explicitly want
# /youtube-status to be reachable.
ENABLE_YOUTUBE_STATUS_PAGE=false
